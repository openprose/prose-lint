use "@anthropic/web-search"

input topic: "Topic to research"

agent researcher:
  model: sonnet
  prompt: "Research carefully"
  persist: project
  skills: ["web-search"]
  permissions:
    read: ["README.md"]
    bash: deny

let notes = session: researcher
  prompt: "Research {topic}"

loop (max: 3):
  session "Refine the findings"
    context: notes

resume: researcher
  prompt: "Summarize the findings"

output result = notes
