    "spec_ref": "openprose/prose@d6e9c64c82a6c56d84b0f9923dd9b7a7e44f8dd5",
    "description": "OpenProse adapter manifest schema for deterministic coding-agent initialization"
  },
  "program_formats": [
    "v1-single-file",
    "v1-multi-service"
  ],
  "channel_roles": [
    "system",
    "developer",
    "user"
  ],
  "attachment_kinds": [
    "program",
    "manifest",
    "service-definition",
    "inputs",
    "workspace",
    "output-instructions"
  ],
