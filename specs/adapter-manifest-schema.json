        "state/filesystem.md"
      ],
      "required_attachments": [
        "manifest"
      ]
    },
    "subagent-v1": {
      "required_for_formats": [
        "v1-single-file",
        "v1-multi-service"
      ],
      "required_files": [
        "primitives/session.md"
      ],
      "required_attachments": [
        "service-definition",
        "inputs",
        "workspace",
        "output-instructions"
      ]
